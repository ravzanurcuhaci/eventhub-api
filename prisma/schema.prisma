generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  role         Role     @default(USER)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  passwordHash String
  events       Event[]  @relation("OrganizerEvents")
  orders       Order[]
}

model Event {
  id          String       @id @default(cuid())
  title       String
  description String?
  date        DateTime
  organizerId String
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  location    String?
  category    EventCategory?
  status      EventStatus  @default(UPCOMING)
  isActive    Boolean      @default(true)
  organizer   User         @relation("OrganizerEvents", fields: [organizerId], references: [id])
  ticketTypes TicketType[]

  @@unique([organizerId, title, date])
}

model TicketType {
  id       String      @id @default(cuid())
  eventId  String
  name     String
  price    Int
  stock    Int
  isActive Boolean     @default(true)
  items    OrderItem[]
  event    Event       @relation(fields: [eventId], references: [id])

  @@unique([eventId, name])
  @@index([eventId])
}

model Order {
  id        String      @id @default(cuid())
  userId    String
  status    OrderStatus @default(PENDING)
  createdAt DateTime    @default(now())
  total     Int         @default(0)
  updatedAt DateTime    @updatedAt
  user      User        @relation(fields: [userId], references: [id])
  items     OrderItem[]
}

model OrderItem {
  orderId      String
  ticketTypeId String
  quantity     Int
  unitPrice    Int
  order        Order      @relation(fields: [orderId], references: [id])
  ticketType   TicketType @relation(fields: [ticketTypeId], references: [id])

  @@id([orderId, ticketTypeId])
  @@index([ticketTypeId])
}

enum Role {
  ADMIN
  ORGANIZER
  USER
}

enum OrderStatus {
  PENDING
  PAID
  CANCELED
}


enum EventCategory {
  MUSIC
  SPORT
  THEATRE
  CONFERENCE
}

enum EventStatus {
  UPCOMING
  ONGOING
  COMPLETED
  CANCELED
}
